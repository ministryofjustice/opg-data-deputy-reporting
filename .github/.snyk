version: v1.25.0
ignore:
  SNYK-JS-LODASH-15869625:
    - '*':
        reason: >
          Vulnerability originates from transitive dependency in
          stoplight/prism base image (@stoplight/http-spec).
          No direct dependency control; build environment prohibits
          patching vendor dependencies. Runtime usage does not expose
          lodash template execution paths.
        expires: 2026-09-01
  SNYK-JS-FASTURI-16642399:
    - '*':
        reason: >
          Vulnerability only appears in mock sirius.
        expires: 2026-09-01
